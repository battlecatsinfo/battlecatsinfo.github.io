{{#> base.html}}

{{#*inline "styles"}}
	{{#> styles}}
	<link rel="stylesheet" href="/gh.css">
	{{/styles}}
{{/inline}}

{{#*inline "styles-inline"}}
	{{#> styles-inline}}
	<style>
	body {
		margin: 0;
		padding: 0;
		background-color: #fff;
	}
	.markdown-body {
		box-sizing: border-box;
		min-width: 200px;
		max-width: 95%;
		margin: 0 auto;
		padding: 45px;
	}

	@media (max-width: 767px) {
		.markdown-body {
			padding: 15px;
		}
	}

	:root.dark {
		body {
			background-color: #0d1117;
		}
	}
	</style>
	{{/styles-inline}}
{{/inline}}

{{#*inline "content"}}
	<article class="markdown-body">
		<h1 id="title"><a class="anchor" href="#title"><span class="octicon octicon-link"></span></a>{{#> title}}{{/title}}</h1>
		{{#> content}}
		{{/content}}
	</article>
{{/inline}}

{{/base.html}}
